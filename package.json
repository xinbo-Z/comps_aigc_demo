{
  "name": "hik-comps-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.3.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "docs:dev": "pnpm --filter @sci-comp/core build && pnpm --filter sci-comp-documention dev",
    "docs:build": "pnpm --filter sci-comp-documention build",
    "docs:preview": "pnpm --filter sci-comp-documention preview",
    "test:watch": "pnpm --filter sci-comp-test test:watch",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "commit": "czg",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "pnpm exec eslint --fix"
    ],
    "*.{ts,tsx,js,mjs,cjs,json,md,css,yml,yaml}": [
      "pnpm exec prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "turbo": "^2.9.6",
    "typescript-eslint": "^8.58.0",
    "cz-git": "^1.12.0"
  }
}
